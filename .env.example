# Backend Environment Variables Example
# Copy this file to .env.local and update with your values

# Database Configuration (PostgreSQL on Render)
DATABASE_URL=postgresql://username:password@host:5432/collabsphere
DATABASE_USER=postgres_user
DATABASE_PASSWORD=your_secure_password

# Server Configuration
PORT=8080

# JWT Configuration
JWT_SECRET=Your-Very-Long-Secure-Secret-Key-Min-32-Characters-2024
JWT_EXPIRATION=86400000

# CORS Configuration (Vercel frontend URL)
CORS_ALLOWED_ORIGINS=https://collabsphere.vercel.app,http://localhost:3000

# Logging
LOG_LEVEL=INFO
